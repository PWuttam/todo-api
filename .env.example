# ============================================
# このファイルは環境変数の見本です。
# コピーして .env を作成して使用してください。
# ============================================

# ------------------------
# Server Settings
# ------------------------
PORT=3000
NODE_ENV=development  # development / production / test

# ------------------------
# Database Settings
# ------------------------
MONGODB_URI=mongodb://127.0.0.1:27017/todo_api

# ------------------------
# JWT Settings
# ------------------------
JWT_SECRET=change-me

# ------------------------
# CORS Settings
# ------------------------
CORS_ORIGIN=http://localhost:5173,http://localhost:3001  # カンマ区切りで複数指定可

# 本番環境では CORS_ORIGIN を必須にして許可 Origin を明示してください
# CORS_ORIGIN=https://app.example.com,https://admin.example.com
